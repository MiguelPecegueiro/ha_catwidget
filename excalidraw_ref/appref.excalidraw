      "updated": 1780213702268,
      "link": null,
      "locked": false,
      "text": "Clientes.Endesa.Endesa_Blocklist Struct\n\nId int ident   \nCPE nvarchar30  -  Receives Carteira.CPE.Trim()\nCUI nvarchar30  -  Receives Carteira.CUI.Trim()\nNIF nvarchar9    -  Receives Morosos.NIF\nContacto1 varchar20 \nContacto2 varchar20\nBlockDate datetime2 - Insertion Date\nReason nvarchar400 - Set Conditional List\nSource varchar50 - Set Conditional List\nServiceID varchar10 - always empty\nIsActive bit - 1\nCreatedAt datetime2 - Insertion Date\nCreatedBy varchar 50 - Default to Reporting.API",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Clientes.Endesa.Endesa_Blocklist Struct\n\nId int ident   \nCPE nvarchar30  -  Receives Carteira.CPE.Trim()\nCUI nvarchar30  -  Receives Carteira.CUI.Trim()\nNIF nvarchar9    -  Receives Morosos.NIF\nContacto1 varchar20 \nContacto2 varchar20\nBlockDate datetime2 - Insertion Date\nReason nvarchar400 - Set Conditional List\nSource varchar50 - Set Conditional List\nServiceID varchar10 - always empty\nIsActive bit - 1\nCreatedAt datetime2 - Insertion Date\nCreatedBy varchar 50 - Default to Reporting.API",
      "autoResize": true,
      "lineHeight": 1.25
    },
