      "link": null,
      "locked": false,
      "text": "Azure - GoConnection--Clientes\n\nTarget:\nClientes.Endesa.Endesa_BlockList\n\nThis is a full replace meaning deleting all previous data where Source matches \nand inserting the new one. Do in trans so rollback is possible.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Azure - GoConnection--Clientes\n\nTarget:\nClientes.Endesa.Endesa_BlockList\n\nThis is a full replace meaning deleting all previous data where Source matches \nand inserting the new one. Do in trans so rollback is possible.",
      "autoResize": true,
      "lineHeight": 1.25
    },
